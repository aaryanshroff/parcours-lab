{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend-v2 && pip install .",
    "watchPatterns": ["backend-v2/**"]
  },
  "deploy": {
    "startCommand": "cd backend-v2 && gunicorn app:app --bind 0.0.0.0:${PORT:-5001}",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
